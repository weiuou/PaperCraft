APP_ENV=development
APP_NAME=AI_PaperCraft_Studio

DATABASE_URL=postgresql+psycopg://papercraft:papercraft_dev@localhost:5432/papercraft
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=papercraft-local-uploads
S3_BUCKET_ARTIFACTS=papercraft-local-artifacts
S3_FORCE_PATH_STYLE=true

MAX_UPLOAD_MB=20
MAX_UPLOAD_IMAGES=3
TASK_TIMEOUT_SECONDS=1800

JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
